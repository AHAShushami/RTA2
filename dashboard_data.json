      {
        "text": "ENVIRONMENT FACTOR :                                                                     - CUACA SELEPAS HUJAN (BERKABUR)",
        "source": "contrib"
      },
      {
        "text": "18/11/2023 (0545) HCW KELUAR DARI RUMAH UNTUK KE TEMPAT KERJA DARI RUMAH DI BUKIT SELAMBAU, SG PETANI.                          - KEADAAN KETIKA MEMANDU AGAK GELAP, JALAN BERKABUS DAN LICIN. MENYUKARKAN PENGLIHATAN SEMASA MEMANDU.             (0605) ",
        "source": "narrative"
      }
    ],
    "Psychosocial / Mental State (Rushing, Stress)": [
      {
        "text": "LORI MASUK KE PETRON SECARA TERGESA-GESA",
        "source": "contrib"
      },
      {
        "text": "HCW dalam keadaan tergesa-gesa ke tempat kerja untuk shift pagi",
        "source": "cause"
      },
      {
        "text": "HCW tergesa-gesa ke tempat kerja kerana laluan jalan yang jem menyebabkan lewat ke tempat kerja.",
        "source": "contrib"
      }
    ],
    "Traffic Flow & Congestion": [
      {
        "text": "Kecuaian kenderaan lain yang tidak menjaga jarak serta kemungkinan faktor kesesakan kenderaan pada tempoh tersebut",
        "source": "contrib"
      },
      {
        "text": "16.08.2023 @ 2.30 petang -Pegawai ini telah berkhidmat selama 23tahun sebagai Jururawat Masyarakat.  Beliau bertugas di Klinik Desa Kangkong selama lebih kurang 12tahun dan tinggal di kuarters klinik berkenaan.  \n\nPegawai terlibat dalam kemalangan be",
        "source": "narrative"
      },
      {
        "text": "Faktor persekitaran \n- kesesakan jalanraya\n- keadaan cuaca hujan renyai",
        "source": "contrib"
      }
    ]
  },
  "theme_desc": {
    "Fatigue / Drowsiness / Microsleep": "Workers experiencing exhaustion from shift work, long hours, or early morning starts, leading to impaired driving alertness.",
    "Other Vehicle At Fault": "Incidents caused by third-party road users—reckless driving, illegal maneuvers, or head-on collisions initiated by other vehicles.",
    "Adverse Weather / Poor Visibility": "Rain, darkness, fog, or wet road surfaces reducing visibility and vehicle control.",
    "Road Condition / Infrastructure": "Poor road maintenance, missing street lighting, narrow lanes, potholes, or hazardous intersections.",
    "Distraction / Loss of Focus": "Driver inattention due to phone use, mental preoccupation, or momentary lapses in concentration.",
    "High Speed / Speeding": "Excessive speed reducing reaction time and increasing impact severity.",
    "Animal on Road": "Wildlife or domestic animals suddenly appearing on the road.",
    "Mechanical Failure": "Vehicle malfunction including brake failure, tire blowouts, or throttle issues.",
    "Early Morning Commute Risk": "Heightened risk during pre-dawn and dawn commuting hours (5-8 AM) when visibility is low.",
    "Long Distance Commute": "Healthcare workers traveling long distances (>50km) between home and workplace.",
    "Post-Shift / Return Journey": "Accidents occurring during the return journey after completing work shifts.",
    "Blind Spot / Sudden Appearance": "Unexpected appearance of vehicles or obstacles, often at intersections.",
    "Psychosocial / Mental State (Rushing, Stress)": "Time pressure, mental stress, or psychological factors leading to risky driving behavior (e.g., rushing to work).",
    "Decision & Maneuvering Errors (Loss of Control)": "Psychomotor or tactical errors such as skidding, pedal misapplication, or failure to perform emergency maneuvers.",
    "Tailgating & Reaction Time": "Following other vehicles too closely or failing to react in time to traffic changes.",
    "Traffic Flow & Congestion": "Incidents occurring during peak hours or heavy traffic congestion.",
    "Other / Unclassified": "Cases with unique or insufficiently detailed causal descriptions."
  },
